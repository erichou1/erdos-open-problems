# Copy this file, fill in your value, and save as .env (never committed).
# Change the URL below to your ChatGPT Project URL.
CHATGPT_PROJECT_URL=https://chatgpt.com/g/g-p-REPLACE_WITH_YOUR_PROJECT_ID/project

# EGMRA trust-domain secrets. Leave these blank in the template. Provision
# independent random values of at least 32 bytes through your secret manager;
# do not reuse one value across trust domains and never commit a populated file.
EGMRA_POLICY_KEY=
EGMRA_EVENT_KEY=
EGMRA_EVIDENCE_KEY=
EGMRA_RELEASE_KEY=
EGMRA_GATE_KEY=
EGMRA_PROMOTION_KEY=
EGMRA_AUTHORITY_KEY=
EGMRA_TRUTH_SNAPSHOT_KEY=
EGMRA_CHECKPOINT_KEY=
EGMRA_MODEL_ATTESTATION_KEY=
EGMRA_INTENT_REVIEW_KEY=
EGMRA_LEAN_CHECKER_KEY=
EGMRA_FORMAL_CORRESPONDENCE_KEY=
EGMRA_LEGACY_REVIEW_KEY=
EGMRA_LEGACY_EVIDENCE_KEY=

# Optional live provider credentials; keep blank when the provider is unused.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
ARISTOTLE_API_KEY=
