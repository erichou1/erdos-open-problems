{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/erdos/ranking-card.schema.json",
  "title": "Erdos Ranking Card",
  "type": "object",
  "required": [
    "problem_id", "problem_number", "rank", "snapshot_id", "snapshot_date",
    "pipeline_version", "model_portfolio", "budget", "budget_config",
    "toolset_version", "run_contract_id", "allocation_context_id",
    "source_snapshot_id", "source_snapshot_sha256", "statement_sha256",
    "allocation_status", "probability", "credible_interval", "uncertainty",
    "prize", "prize_status", "selection_priority_tier",
    "literature_policy_version", "literature_coverage_status",
    "local_literature_artifact_hash", "live_literature_artifact_hashes",
    "literature_features", "literature_coverage_gaps",
    "base_acquisition_score", "literature_adjustment", "selection_score",
    "recommended_attack_mode", "recommended_attack_modes",
    "research_directive", "research_directive_sha256",
    "strongest_positive_signals", "largest_risks",
    "statement_status", "literature_status", "lean_status",
    "computational_status", "estimated_compute", "estimated_review_cost",
    "reason_selected"
  ],
  "properties": {
    "problem_id": {"type": "string", "pattern": "^erdos-[0-9]+$"},
    "problem_number": {"type": "integer", "minimum": 1},
    "rank": {"type": "integer", "minimum": 1},
    "snapshot_id": {"type": "string"},
    "snapshot_date": {"type": "string", "format": "date"},
    "pipeline_version": {"type": "string"},
    "model_portfolio": {"type": "string"},
    "budget": {"type": "string"},
    "budget_config": {"type": "object"},
    "toolset_version": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "run_contract_id": {"type": ["string", "null"]},
    "allocation_context_id": {"type": ["string", "null"]},
    "source_snapshot_id": {"type": "string"},
    "source_snapshot_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "statement_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "allocation_status": {"type": "string"},
    "prize": {"type": ["string", "null"]},
    "prize_status": {"enum": ["unpaid", "paid", "unknown"]},
    "selection_priority_tier": {"type": "integer", "minimum": 0, "maximum": 2},
    "literature_status_tier": {"type": "integer", "minimum": 0, "maximum": 1},
    "literature_policy_version": {"const": "literature-ranking-v1"},
    "literature_coverage_status": {
      "enum": ["not_available", "local_only", "partial", "live_complete"]
    },
    "local_literature_artifact_hash": {
      "type": "string", "pattern": "^$|^[0-9a-f]{64}$"
    },
    "live_literature_artifact_hashes": {
      "type": "array",
      "items": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
    },
    "literature_features": {
      "type": "object",
      "required": ["foothold", "reuse", "machinery_risk", "status_risk", "components"],
      "properties": {
        "foothold": {"type": "number", "minimum": 0, "maximum": 1},
        "reuse": {"type": "number", "minimum": 0, "maximum": 1},
        "machinery_risk": {"type": "number", "minimum": 0, "maximum": 1},
        "status_risk": {"type": "number", "minimum": 0, "maximum": 1},
        "components": {"type": "object"}
      }
    },
    "literature_coverage_gaps": {"type": "array", "items": {"type": "string"}},
    "base_acquisition_score": {"type": "number"},
    "literature_adjustment": {"type": "number", "minimum": -0.02, "maximum": 0.03},
    "selection_score": {"type": "number"},
    "probability": {"type": "number", "minimum": 0, "maximum": 1},
    "credible_interval": {
      "type": "array", "prefixItems": [
        {"type": "number", "minimum": 0, "maximum": 1},
        {"type": "number", "minimum": 0, "maximum": 1}
      ], "minItems": 2, "maxItems": 2
    },
    "uncertainty": {"type": "number", "minimum": 0, "maximum": 1},
    "recommended_attack_mode": {"type": "string"},
    "recommended_attack_modes": {
      "type": "array", "items": {"type": "string"}, "minItems": 1
    },
    "research_directive": {"type": "object"},
    "research_directive_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "strongest_positive_signals": {"type": "array", "items": {"type": "string"}},
    "largest_risks": {"type": "array", "items": {"type": "string"}},
    "statement_status": {"type": "string"},
    "literature_status": {"type": "string"},
    "lean_status": {"type": "string"},
    "computational_status": {"type": "string"},
    "estimated_compute": {},
    "estimated_review_cost": {},
    "reason_selected": {"type": "string"},
    "model_version": {"type": "string"},
    "calibration_status": {"type": "string"},
    "allocation_lane": {"enum": ["exploitation", "protected_exploration"]},
    "allocation_rank": {"type": "integer", "minimum": 1},
    "lane_rank": {"type": "integer", "minimum": 1}
  }
}
