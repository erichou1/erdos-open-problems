{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/erdos/subproblem-card.schema.json",
  "title": "Explicit Source Subproblem Card",
  "type": "object",
  "required": [
    "schema_version", "subproblem_id", "parent_problem_id", "problem_number",
    "part_index", "subproblem_contract_sha256", "statement", "snapshot_id", "pipeline_version",
    "model_portfolio", "budget", "run_contract_id", "parent_run_contract_id",
    "recommended_attack_modes", "priority_score", "rank"
  ],
  "properties": {
    "schema_version": {"const": 2},
    "subproblem_id": {
      "type": "string",
      "pattern": "^erdos-[0-9]+-part-[0-9]{2}-[0-9a-f]{8}$"
    },
    "parent_problem_id": {"type": "string", "pattern": "^erdos-[0-9]+$"},
    "problem_number": {"type": "integer", "minimum": 1},
    "part_index": {"type": "integer", "minimum": 1},
    "subproblem_contract_sha256": {
      "type": "string", "pattern": "^[0-9a-f]{64}$"
    },
    "statement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "original", "normalized", "statement_sha256",
        "focus_question", "focus_question_sha256"
      ],
      "properties": {
        "original": {"type": "string", "minLength": 1},
        "normalized": {"type": "string", "minLength": 1},
        "statement_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "focus_question": {"type": "string", "minLength": 1},
        "focus_question_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "snapshot_id": {"type": "string"},
    "pipeline_version": {"type": "string"},
    "model_portfolio": {"type": "string"},
    "budget": {"type": "string"},
    "run_contract_id": {"type": ["string", "null"]},
    "parent_run_contract_id": {"type": ["string", "null"]},
    "recommended_attack_modes": {"type": "array", "items": {"type": "string"}},
    "priority_score": {"type": "number", "minimum": 0, "maximum": 1},
    "rank": {"type": "integer", "minimum": 1}
  },
  "additionalProperties": false
}
