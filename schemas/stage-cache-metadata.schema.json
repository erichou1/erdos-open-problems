{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/erdos/stage-cache-metadata.schema.json",
  "title": "Validated Stage Cache Metadata",
  "type": "object",
  "required": [
    "cache_schema_version", "stage", "prompt_sha256", "response_sha256",
    "run_contract", "run_contract_id", "cache_context_id", "context_id",
    "recorded_at"
  ],
  "additionalProperties": false,
  "properties": {
    "cache_schema_version": {"const": 3},
    "stage": {"type": "string", "minLength": 1},
    "prompt_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "response_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "run_contract": {"$ref": "#/$defs/runContract"},
    "run_contract_id": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "cache_context_id": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "context_id": {"type": "string"},
    "recorded_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "nonemptyIdentity": {
      "type": "object",
      "minProperties": 1
    },
    "runContract": {
      "type": "object",
      "required": [
        "run_contract_schema_version", "statement_sha256", "source_snapshot",
        "pipeline_fingerprint", "research_directive_sha256",
        "model_portfolio", "toolset", "budget",
        "execution_config", "dependencies", "runtime"
      ],
      "additionalProperties": false,
      "properties": {
        "run_contract_schema_version": {"const": 2},
        "statement_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "source_snapshot": {
          "type": "object",
          "required": ["id", "sha256"],
          "additionalProperties": false,
          "properties": {
            "id": {"type": "string", "minLength": 1},
            "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
          }
        },
        "pipeline_fingerprint": {"type": "string", "minLength": 1},
        "research_directive_sha256": {
          "type": "string", "pattern": "^[0-9a-f]{64}$"
        },
        "model_portfolio": {"type": "string", "minLength": 1},
        "toolset": {"$ref": "#/$defs/nonemptyIdentity"},
        "budget": {"$ref": "#/$defs/nonemptyIdentity"},
        "execution_config": {"$ref": "#/$defs/nonemptyIdentity"},
        "dependencies": {"$ref": "#/$defs/nonemptyIdentity"},
        "runtime": {"$ref": "#/$defs/nonemptyIdentity"}
      }
    }
  }
}
