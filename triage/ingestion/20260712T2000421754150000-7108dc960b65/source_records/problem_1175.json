      "sha256": "ed000bd6fe5bf76f4f96527d66dddcba9f6bd6f00e4797654c263f1a886047aa",
      "source_region": "div.problem-additional-text",
      "text": "Shelah proved that a negative answer is consistent if $\\kappa=\\lambda=\\aleph_1$."
    },
    "statement": {
      "sha256": "9135cb7d68b7b25d260b10911c7f9c607d8364fe3cf473376de0028d5732fb0b",
      "source_region": "div#content",
      "text": "Let $\\kappa$ be an uncountable cardinal. Must there exist a cardinal $\\lambda$ such that every graph with chromatic number $\\lambda$ contains a triangle-free subgraph with chromatic number $\\kappa$?"
    }
  },
