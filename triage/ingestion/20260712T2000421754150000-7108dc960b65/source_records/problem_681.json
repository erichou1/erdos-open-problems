      "sha256": "5f08a3a32c8725f8436cc280d72782f7efe1408ecfc98e50d5a3e472d752f878",
      "source_region": "div.problem-additional-text",
      "text": "Related to questions of Erd\\H{o}s, Eggleton, and Selfridge. This may be true with $k^2$ replaced by $k^d$ for any $d$.\n\nSee also [680] and [682]."
    },
    "statement": {
      "sha256": "7e2defebabde947833855b70ea2630bee2975660bfa921d1e3fdb0a71bdcb876",
      "source_region": "div#content",
      "text": "Is it true that for all large $n$ there exists $k$ such that $n+k$ is composite and\\[p(n+k)>k^2,\\]where $p(m)$ is the least prime factor of $m$?"
    }
  },
