      "source_region": "div.problem-additional-text",
      "text": "[Gu04] Guy, Richard K., Unsolved problems in number theory. (2004), xviii+437."
    },
    "remarks": {
      "sha256": "4f10b7c06365a6db145b553dc59cb909c1645a7089597d99e7a095635d8deec5",
      "source_region": "div.problem-additional-text",
      "text": "This is discussed in problem B9 of Guy's collection \\cite{Gu04}."
    },
    "statement": {
      "sha256": "044648314101dd87215d9d7016b0ba65f7ff16da5c125c26409254c5f69e77aa",
      "source_region": "div#content",
      "text": "Let $\\sigma_1(n)=\\sigma(n)$, the sum of divisors function, and $\\sigma_k(n)=\\sigma(\\sigma_{k-1}(n))$. Is it true that for all $n\\geq 2$\\[\\lim_{k\\to \\infty} \\sigma_k(n)^{1/k}=\\infty?\\]"
    }
